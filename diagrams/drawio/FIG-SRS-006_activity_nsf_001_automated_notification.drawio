        <mxCell id="decision_delivered" value="Delivered?" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lane_channel"><mxGeometry x="75" y="805" width="150" height="90" as="geometry"/></mxCell>
        <mxCell id="audit" value="Create AuditRecord for notification event" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;" vertex="1" parent="lane_result"><mxGeometry x="35" y="550" width="205" height="70" as="geometry"/></mxCell>
        <mxCell id="observable_success" value="Observable result&#xa;recipient receives notification or sees in-app alert" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;strokeWidth=2;" vertex="1" parent="lane_result"><mxGeometry x="35" y="705" width="205" height="90" as="geometry"/></mxCell>
        <mxCell id="observable_failure" value="Observable result&#xa;failed or suppressed status is visible for authorized review" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;dashed=1;" vertex="1" parent="lane_result"><mxGeometry x="35" y="840" width="205" height="90" as="geometry"/></mxCell>
        <mxCell id="final" value="" style="ellipse;shape=doubleEllipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="lane_result"><mxGeometry x="120" y="975" width="34" height="34" as="geometry"/></mxCell>
